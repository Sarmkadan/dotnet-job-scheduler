{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "JobScheduler": {
    "ConnectionString": "Data Source=scheduler.db",
    "MaxConcurrentJobs": 10,
    "DefaultTimeoutSeconds": 300,
    "DefaultMaxRetries": 3,
    "DefaultRetryBackoffSeconds": 5,
    "QueuePollIntervalMs": 5000,
    "EnableCleanup": true,
    "CleanupIntervalMs": 300000
  }
}
